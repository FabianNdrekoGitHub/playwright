# Form URL to open and submit
FORM_URL=https://example.com/your-form

# SQLite database path
DB_PATH=./data/submissions.db

# Field mapping: CSS selectors -> database column names (JSON object)
# Example: {"#email": "email", "input[name=\"name\"]": "full_name"}
FIELD_MAPPING_JSON={"input[name=\"email\"]": "email", "input[name=\"name\"]": "full_name", "textarea[name=\"message\"]": "message"}

# Submit button selector
SUBMIT_SELECTOR=button[type="submit"]

# Optional: selector that appears on success (e.g. thank-you message)
# SUCCESS_INDICATOR=.thank-you

# Min/max delay between submissions (milliseconds)
DELAY_MIN_MS=30000
DELAY_MAX_MS=60000

# Timeout for page load and actions (ms)
TIMEOUT_MS=30000

# Run browser with visible window (set to false to see the browser)
HEADLESS=true

# Proxies: either a file path (one proxy per line) or comma-separated list
# Format: http://host:port or http://user:pass@host:port
# PROXY_LIST_PATH=./proxies.txt
# PROXY_LIST=http://proxy1:8080,http://proxy2:8080
